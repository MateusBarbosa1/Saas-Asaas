// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  plan String
  phoneNumber Int
  createdAt DateTime @default(now())
  sites Sites[]
}

model Sites {
  id           String   @id @default(uuid())
  userId       String
  user         Users    @relation(fields: [userId], references: [id])
  name         String
  url          String?
  type         String   @default("site") // "site" | "landing"
  status       String   @default("em-desenvolvimento") // em-desenvolvimento | no-ar | pausado
  currentStage Int      @default(1)
  createdAt    DateTime @default(now())

  pages   SitePages[]
  updates SiteUpdates[]
  files   SiteFiles[]
  plan    SitePlan?
}

model SitePages {
  id     String  @id @default(uuid())
  siteId String
  site   Sites   @relation(fields: [siteId], references: [id])
  name   String
  done   Boolean @default(false)
}

model SiteUpdates {
  id     String   @id @default(uuid())
  siteId String
  site   Sites    @relation(fields: [siteId], references: [id])
  text   String
  date   DateTime @default(now())
}

model SiteFiles {
  id     String @id @default(uuid())
  siteId String
  site   Sites  @relation(fields: [siteId], references: [id])
  name   String
  size   String
}

model SitePlan {
  id          String   @id @default(uuid())
  siteId      String   @unique
  site        Sites    @relation(fields: [siteId], references: [id])
  name        String
  price       String
  cycle       String
  nextPayment String?
  includes    String[]
}